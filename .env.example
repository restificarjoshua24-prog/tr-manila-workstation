# TR Manila Workstation Reservation System - Environment Variables Template
# Copy this file to .env and update with your actual values

# Flask Configuration
SECRET_KEY=your-secret-key-change-this-in-production
DATABASE_URL=sqlite:///tr_manila_workstation.db

# For production, use PostgreSQL:
# DATABASE_URL=postgresql://username:password@localhost:5432/trmanila_db

# Microsoft 365 Integration (Optional)
# To enable Outlook calendar integration, register an app in Azure Portal
# and fill in the following values:

M365_CLIENT_ID=
M365_CLIENT_SECRET=
M365_TENANT_ID=
OUTLOOK_ENABLED=False

# Set to True after configuring Azure app:
# OUTLOOK_ENABLED=True

# Application Settings
FLASK_ENV=development
# For production: FLASK_ENV=production